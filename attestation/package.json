    "@midnight-ntwrk/wallet-sdk-shielded": "2.1.0",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "2.1.0",
    "axios": "^1.14.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.1.2",
    "rxjs": "^7.8.2",
    "testcontainers": "^11.13.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@midnight-ntwrk/midnight-js-compact": "4.0.2",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
