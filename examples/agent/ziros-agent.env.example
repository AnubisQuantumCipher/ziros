# Copy this file to ~/.ziros/agent.env and source it before using the agent.

export PATH="$HOME/.local/bin:$PATH"

# Local-first assistant-model routing.
# Preferred Apple-Silicon local endpoint.
# export ZIROS_AGENT_MLX_BASE_URL="http://127.0.0.1:8080"

# Alternate local OpenAI-compatible endpoint.
# export ZIROS_AGENT_MODEL_BASE_URL="http://127.0.0.1:8000"
# export OPENAI_BASE_URL="http://127.0.0.1:8000"

# Optional Ollama endpoint.
# export OLLAMA_HOST="http://127.0.0.1:11434"

# Optional Midnight headless wallet diagnostics.
# export MIDNIGHT_WALLET_SEED="replace-me"
# export MIDNIGHT_WALLET_MNEMONIC="replace me with a mnemonic"

# Optional EVM local harness defaults.
# export ETH_RPC_URL="http://127.0.0.1:8545"

# Never commit secrets copied from this file.
