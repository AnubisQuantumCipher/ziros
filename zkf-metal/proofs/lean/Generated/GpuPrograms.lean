namespace ZkfMetalProofs

inductive KernelFamily where
  | hash
  | poseidon2
  | ntt
  | msm
  | fieldOps
  | poly
  | fri
  | constraintEval
  | msmAux
deriving Repr

inductive FieldFamily where
  | bytes
  | goldilocks
  | babyBear
  | bn254Scalar
  | pallasScalar
  | vestaScalar
deriving Repr

inductive CurveFamily where
  | bn254
  | pallas
  | vesta
deriving Repr

inductive MsmRoute where
  | classic
  | naf
  | hybrid
  | fullGpu
  | tensor
deriving Repr

inductive NumericExpr where
  | natConst (value : Nat)
  | symbol (name : String)
  | add (lhs rhs : NumericExpr)
  | sub (lhs rhs : NumericExpr)
  | mul (lhs rhs : NumericExpr)
  | divCeil (lhs rhs : NumericExpr)
  | modNat (lhs rhs : NumericExpr)
deriving Repr

inductive BooleanExpr where
  | truth
  | eqExpr (lhs rhs : NumericExpr)
  | geExpr (lhs rhs : NumericExpr)
  | leExpr (lhs rhs : NumericExpr)
  | isPowerOfTwo (value : NumericExpr)
  | isMultipleOf (value : NumericExpr) (divisor : Nat)
  | allOf (clauses : List BooleanExpr)
deriving Repr

structure SymbolDomain where
  name : String
  minValue : Nat
  maxValue : Option Nat
  nonZero : Bool
  powerOfTwo : Bool
  multipleOf : Option Nat
deriving Repr

structure ThreadIndexMap where
  globalIndex : NumericExpr
  laneIndex : Option NumericExpr
  batchIndex : Option NumericExpr
  guard : BooleanExpr
deriving Repr

inductive MemoryRegionKind where
  | globalInput
  | globalOutput
  | shared
  | constant
  | scratch
deriving Repr

structure RegionSlice where
  name : String
  kind : MemoryRegionKind
  start : NumericExpr
  len : NumericExpr
  bound : NumericExpr
  elementBytes : Nat
deriving Repr

inductive TransitionOperator where
  | sha256MessageSchedule
  | sha256CompressionRound
  | keccakTheta
  | keccakRhoPi
  | keccakChiIota
  | poseidon2ExternalRound
  | poseidon2MatrixLayer
  | poseidon2SBox
  | poseidon2InternalRound
  | fieldAdd
  | fieldSub
  | fieldMul
  | fieldInvPrefix
  | fieldInvBackprop
  | nttBitReverse
  | nttButterflyStage
  | nttSmallTransform
  | nttHybridStage
  | polyEval
  | polyBatchEval
  | polyQuotient
  | polyCosetShift
  | friFold
  | constraintEval
  | msmBucketAssign
  | msmBucketAccumulate
  | msmBucketReduce
  | msmWindowCombine
  | msmBucketCount
  | msmBucketScatter
  | msmSortedAccumulate
  | layoutWriteback
deriving Repr

structure KernelStep where
  name : String
  operator : TransitionOperator
  arithmeticDomain : String
  reads : List String
  writes : List String
deriving Repr

structure BarrierPoint where
  afterStep : Nat
  scope : String
deriving Repr

structure LoweringBinding where
  stepIndex : Nat
  entrypoint : String
  sourcePath : String
  library : String
  bindingKind : String
deriving Repr

structure ExpectedArgument where
  name : String
  index : Nat
  kind : String
  access : String
deriving Repr

structure KernelAttestation where
  libraryId : String
  entrypoint : String
  metallibSha256 : String
  reflectionSha256 : String
  pipelineDescriptorSha256 : String
  arguments : List ExpectedArgument
deriving Repr

structure LoweringCertificate where
  sourceSha256 : List (String × String)
  sourcePaths : List String
  entrypoints : List String
  toolchainCompiler : String
  toolchainXcode : String
  toolchainSdk : String
  entrypointAttestations : List KernelAttestation
  reflectionPolicy : String
  workgroupPolicy : String
  stepBindings : List LoweringBinding
deriving Repr

