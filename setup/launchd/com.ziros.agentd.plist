<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.ziros.agentd</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/zsh</string>
		<string>-lc</string>
		<string>"$HOME/Desktop/ZirOS/setup/launchd/ziros-agentd-launch.sh"</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>/tmp/ziros-agentd.stdout.log</string>
	<key>StandardErrorPath</key>
	<string>/tmp/ziros-agentd.stderr.log</string>
	<key>ProcessType</key>
	<string>Interactive</string>
</dict>
</plist>
