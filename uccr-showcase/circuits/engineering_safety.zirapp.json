    { "name": "__sha_b31",                   "visibility": "private" },
    { "name": "safety_factor_bps",           "visibility": "constant", "constant": "15000" },
    { "name": "safety_commitment_hi",        "visibility": "public" },
    { "name": "safety_commitment_lo",        "visibility": "public" }
  ],
  "ops": [
    { "kind": "range", "signal": "design_load_capacity_scaled", "bits": 32 },
    { "kind": "range", "signal": "applied_load_scaled",         "bits": 32 },
    { "kind": "range", "signal": "material_yield_stress_scaled","bits": 32 },
    { "kind": "range", "signal": "applied_stress_scaled",       "bits": 32 },
    { "kind": "range", "signal": "design_id_hash",              "bits": 32 },
    { "kind": "range", "signal": "blinding",                    "bits": 32 },
    {
      "kind": "equal",
      "lhs": { "op": "signal", "args": "__load_margin" },
      "rhs": {
        "op": "sub",
        "args": [
          { "op": "signal", "args": "design_load_capacity_scaled" },
          { "op": "signal", "args": "applied_load_scaled" }
        ]
      }
    },
    { "kind": "range", "signal": "__load_margin", "bits": 32 },
    {
      "kind": "equal",
      "lhs": { "op": "signal", "args": "__stress_margin" },
