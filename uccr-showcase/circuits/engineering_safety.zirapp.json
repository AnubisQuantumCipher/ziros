        "op": "sub",
        "args": [
          { "op": "signal", "args": "material_yield_stress_scaled" },
          { "op": "signal", "args": "applied_stress_scaled" }
        ]
      }
    },
    { "kind": "range", "signal": "__stress_margin", "bits": 32 },
    {
      "kind": "black_box",
      "op": "sha256",
      "inputs": [
        { "op": "signal", "args": "design_id_hash" },
        { "op": "signal", "args": "design_load_capacity_scaled" },
        { "op": "signal", "args": "applied_load_scaled" },
        { "op": "signal", "args": "blinding" }
      ],
      "outputs": [
        "__sha_b0",  "__sha_b1",  "__sha_b2",  "__sha_b3",
        "__sha_b4",  "__sha_b5",  "__sha_b6",  "__sha_b7",
        "__sha_b8",  "__sha_b9",  "__sha_b10", "__sha_b11",
        "__sha_b12", "__sha_b13", "__sha_b14", "__sha_b15",
        "__sha_b16", "__sha_b17", "__sha_b18", "__sha_b19",
        "__sha_b20", "__sha_b21", "__sha_b22", "__sha_b23",
        "__sha_b24", "__sha_b25", "__sha_b26", "__sha_b27",
        "__sha_b28", "__sha_b29", "__sha_b30", "__sha_b31"
      ],
      "params": { "input_num_bits": "8" }
    },
    {
      "kind": "equal",
      "lhs": { "op": "signal", "args": "safety_commitment_hi" },
      "rhs": { "op": "signal", "args": "__sha_b0" }
    },
    {
      "kind": "equal",
      "lhs": { "op": "signal", "args": "safety_commitment_lo" },
      "rhs": { "op": "signal", "args": "__sha_b31" }
    }
  ],
  "expected_inputs": ["design_load_capacity_scaled", "applied_load_scaled", "material_yield_stress_scaled", "applied_stress_scaled", "design_id_hash", "blinding"],
  "public_outputs": ["safety_commitment_hi", "safety_commitment_lo"],
