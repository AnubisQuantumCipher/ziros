{
  "program": {
    "name": "uccr_engineering_safety",
    "field": "pasta-fp"
  },
  "description": "Prove that a structural or mechanical design meets required safety factor tolerances (load capacity vs. design load, material stress vs. yield strength) without revealing proprietary CAD parameters, material specifications, or exact design margins. Applicable to aerospace certification (DO-178C/DO-254), civil structural certification, and nuclear safety-critical system attestation.",
  "signals": [
    { "name": "design_load_capacity_scaled", "visibility": "private" },
    { "name": "applied_load_scaled",         "visibility": "private" },
    { "name": "material_yield_stress_scaled","visibility": "private" },
    { "name": "applied_stress_scaled",       "visibility": "private" },
    { "name": "design_id_hash",              "visibility": "private" },
    { "name": "blinding",                    "visibility": "private" },
